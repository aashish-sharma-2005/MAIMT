<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Forgot Password</title>
    <link rel="stylesheet" href="/css/forgotemail.css">
</head>

<body>

    <div class="container">

        <!-- STEP 1: EMAIL -->
        <div id="emailStep">
            <h2>Enter Email</h2>
            <input type="email" id="email" placeholder="Enter your email">
            <button onclick="sendotp(event)">Send OTP</button>
            <span id="emailError" style="color:red; font-size:13px;"></span>
        </div>

        <!-- STEP 2: OTP -->
        <div id="otpStep" style="display:none;">
            <h2>Enter OTP</h2>
            <input type="text" id="otp" placeholder="Enter OTP">
            <button onclick="verifyotp(event)">Verify OTP</button>
            <span id="otpError" style="color:red; font-size:13px;"></span>
        </div>
        <div id="passwordStep" style="display:none;">
            <h2>Enter New Password</h2>
            <input type="password" id="newPassword" placeholder="New Password">
            <button onclick="resetPassword()" id="resetBtn">Reset Password</button>
            <span id="passError" style="color:red; font-size:13px;"></span>
        </div>
    </div>

    <script>
    let timer;

    // ================= SEND OTP =================
    function sendotp(e) {
        const email = document.getElementById("email").value.trim();
        const btn = e.target;
        const error = document.getElementById("emailError");

        error.innerText = "";

        // ❌ empty
        if (!email) {
            error.innerText = "Please enter email ❌";
            return;
        }

        // ❌ invalid format
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(email)) {
            error.innerText = "Invalid email ❌";
            return;
        }

        btn.disabled = true;
        btn.innerText = "Sending OTP...";

        fetch("/auth/sendotp", {
            method: "POST",
            headers: {"Content-Type": "application/json"},
            body: JSON.stringify({ email })
        })
        .then(res => res.json())
        .then(data => {
            btn.disabled = false;
            btn.innerText = "Send OTP";

            if (data.status) {
                document.getElementById("emailStep").style.display = "none";
                document.getElementById("otpStep").style.display = "block";
                startTimer();
            } else {
                error.innerText = data.msg || "Something went wrong ❌";
            }
        })
        .catch(() => {
            btn.disabled = false;
            btn.innerText = "Send OTP";
            error.innerText = "Server error ❌";
        });
    }

    // ================= TIMER =================
    function startTimer() {
        clearTimeout(timer);

        timer = setTimeout(() => {
            alert("Timeout ⏱️ Please try again");
            window.location.reload();
        }, 60000);
    }

    // ================= VERIFY OTP =================
    function verifyotp(e) {
        const otp = document.getElementById("otp").value.trim();
        const btn = e.target;
        const error = document.getElementById("otpError");

        error.innerText = "";

        if (!otp) {
            error.innerText = "Enter OTP ❌";
            return;
        }

        if (otp.length !== 4 && otp.length !== 6) {
            error.innerText = "Invalid OTP ❌";
            return;
        }

        btn.disabled = true;
        btn.innerText = "Verifying...";

        fetch("/auth/verifyotp", {
            method: "POST",
            headers: {"Content-Type": "application/json"},
            body: JSON.stringify({ otp })
        })
        .then(res => res.json())
        .then(data => {
            btn.disabled = false;
            btn.innerText = "Verify OTP";

            if (data.status) {
                clearTimeout(timer);

                document.getElementById("otpStep").style.display = "none";
                document.getElementById("passwordStep").style.display = "block";
            } else {
                error.innerText = data.msg || "Wrong OTP ❌";
                document.getElementById("emailStep").style.display = "none";
                document.getElementById("otpStep").style.display = "block";
            }
        })
        .catch(() => {
            btn.disabled = false;
            btn.innerText = "Verify OTP";
            error.innerText = "Server error ❌";
        });
    }

    // ================= RESET PASSWORD =================
    function resetPassword() {
        const password = document.getElementById("newPassword").value.trim();
        const btn = document.getElementById("resetBtn");
        const error = document.getElementById("passError");

        error.innerText = "";

        if (!password) {
            error.innerText = "Enter new password ❌";
            return;
        }

        if (password.length < 3) {
            error.innerText = "Min 3 characters required ❌";
            return;
        }

        btn.disabled = true;
        btn.innerText = "Updating...";

        fetch("/auth/resetpassword", {
            method: "POST",
            headers: {"Content-Type": "application/json"},
            body: JSON.stringify({ password })
        })
        .then(res => res.json())
        .then(data => {
            btn.disabled = false;
            btn.innerText = "Reset Password";
            if (data.status) {
                window.location.href = "/";
            } else {
                error.innerText = data.msg;
            }
        })
        .catch(() => {
            btn.disabled = false;
            btn.innerText = "Reset Password";
            error.innerText = "Server error ❌";
        });
    }
</script>

</body>

</html>