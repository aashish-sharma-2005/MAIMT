<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/profile.css">
</head>

<body>
    <div class="profile-page">
        <div class="profile">
            <!-- COVER -->
            <div class="cover">
                <img src="<%= user.coverPhoto || 'https://via.placeholder.com/1000x250' %>" class="cover-img"
                    id="coverImage">
                <label for="coverInput" class="cover-camera">📷</label>
                <input type="file" id="coverInput" hidden onchange="uploadCoverPic()">
                <!-- PROFILE PIC -->
                <div class="profile-pic-wrapper">
                    <img src="<%= user.profilePic && user.profilePic !== '' ? user.profilePic : 'https://via.placeholder.com/120' %>"
                        class="profile-pic" id="profileImage">
                    <label for="fileInput" class="camera-btn">📷</label>
                    <input type="file" id="fileInput" hidden onchange="uploadProfilePic()">
                </div>
                <!-- NAME -->
                <div class="user-info">
                    <h2>
                        <%= user.name %>
                    </h2>
                    <p>@<%= user.email.split('@')[0] %>
                    </p>
                </div>
            </div>
            <!-- ACTION BUTTONS -->
            <div class="actions">
                <% if (currentUser.friends.includes(user._id.toString())) { %>
                    <button class="friends" disabled>Friends</button>
                    <% } else if (currentUser.requestSend.includes(user._id.toString())) { %>
                        <button class="requested" disabled>Requested</button>
                        <% } else if (currentUser.requestRecieve.includes(user._id.toString())) { %>
                            <button class="accept" onclick="acceptFriend(`<%= user._id %>`)">Accept</button>
                            <% } else { %>
                                <button onclick="addFriend(`<%= user._id %>`)" class="add">Add Friend</button>
                                <% } %>
                                    <button class="msg">Message</button>
            </div>
            <!-- INFO -->
            <div class="card">
                <p><b>Friends:</b>
                    <%= user.friends.length %>
                </p>
            </div>
            <!-- tabs -->
            <div class="tabs">
                <button class="active" onclick="showSection('all', this)">All</button>
                <button onclick="showSection('about', this)">About</button>
                <button onclick="showSection('friends', this)">Friends</button>
                <button onclick="showSection('photos', this)">Photos</button>
                <button onclick="showSection('reels', this)">Reels</button>
            </div>
            <div class="content">
                <!-- ALL -->
                <div id="all" class="section">
                    <%- include('profilefunctions/all',{user:profileUser,currentUser:currentUser,friends:friends}) %>
                </div>
                <!-- ABOUT -->
                <div id="about" class="section" style="display:none;">
                    <%- include('profilefunctions/about',{user:profileUser,currentUser:currentUser,friends:friends}) %>
                </div>
                <!-- FRIENDS -->
                <div id="friends" class="section" style="display:none;">
                    <%- include('profilefunctions/friends',{user:profileUser,currentUser:currentUser,friends:friends})%>
                </div>
                <!-- PHOTOS -->
                <div id="photos" class="section" style="display:none;">
                    <%- include('profilefunctions/photos',{user:profileUser,currentUser:currentUser,friends:friends,posts:posts})
                        %>
                </div>
                <!-- REELS -->
                <div id="reels" class="section" style="display:none;">
                    <%- include('profilefunctions/reels',{user:profileUser,currentUser:currentUser,friends:friends}) %>
                </div>
            </div>

        </div>

    </div>

    <script>
        function showAboutTab(e, id) {
            // hide all tabs
            const tabs = document.querySelectorAll('.about-tab');
            tabs.forEach(t => t.style.display = 'none');
            // show selected
            document.getElementById(id).style.display = 'block';
            // active class
            const items = document.querySelectorAll('.about-left li');
            items.forEach(i => i.classList.remove('active'));
            e.target.classList.add('active');
        }
        function profile(id) {
            window.location.href = `/user/profile/${id}`;
        }
        function showSection(id, el) {
            // sab sections hide
            const sections = document.querySelectorAll('.section');
            sections.forEach(sec => sec.style.display = 'none');

            // selected show
            document.getElementById(id).style.display = 'block';

            // sab tabs se active remove
            const tabs = document.querySelectorAll('.tabs button');
            tabs.forEach(btn => btn.classList.remove('active'));

            // clicked tab active
            el.classList.add('active');
        }
        function acceptFriend(id) {
            fetch(`/user/friends/accept/${id}`, {
                method: "PATCH",
                headers: { 'content-type': 'application/json' }
            })
                .then(res => res.json())
                .then(() => {
                    window.location.reload();
                })
        }
        function addFriend(id) {
            fetch(`/user/friends/accept/${id}`, {
                method: "PATCH",
                headers: { 'content-type': 'application/json' }
            })
                .then(res => res.json())
                .then(() => {
                    window.location.reload();
                })
        }
        function addFriend(id) {
            fetch(`/user/friends/${id}`, {
                method: "PATCH",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({})
            })
                .then(res => res.json())   // ✅ fixed
                .then(data => {
                    window.location.reload();
                })
        }
    </script>
</body>

</html>