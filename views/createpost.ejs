<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Post</title>

    <link rel="stylesheet" href="/css/createpost.css">
</head>

<body>

    <div class="post-container">
        <form action="/user/<%= user._id %>/createPost" method="POST" enctype="multipart/form-data" class="post-form">
            <textarea name="content" placeholder="What's on your mind?" required></textarea>
            <!-- Toggle -->
            <div class="type-select">
                <label><input type="radio" name="type" value="image" checked> Image</label>
                <label><input type="radio" name="type" value="video"> Video</label>
            </div>
            <!-- Image -->
            <input type="file" name="image" accept="image/*" id="imageInput">
            <!-- Video -->
            <input type="file" name="video" accept="video/*" id="videoInput" style="display:none;">
            <!-- Privacy -->
            <select name="privacy">
                <option value="public">🌍 Public</option>
                <option value="friends">👥 Friends</option>
                <option value="private">🔒 Only Me</option>
            </select>
            <button id="postBtn" type="submit">Post</button>
        </form>
    </div>

<script>
    // inputs
    const imageInput = document.getElementById("imageInput");
    const videoInput = document.getElementById("videoInput");
    const radios = document.querySelectorAll('input[name="type"]');
    const textarea = document.querySelector("textarea");

    // form + button
    const form = document.querySelector(".post-form");
    const btn = document.getElementById("postBtn");

    // 🔥 toggle image/video
    radios.forEach(radio => {
        radio.addEventListener("change", () => {
            if (radio.value === "image") {
                imageInput.style.display = "block";
                videoInput.style.display = "none";
                videoInput.value = "";
            } else {
                videoInput.style.display = "block";
                imageInput.style.display = "none";
                imageInput.value = "";
            }
            checkForm(); // 👈 important
        });
    });

    // 🔥 check form validation
    function checkForm() {
        let type = document.querySelector('input[name="type"]:checked').value;

        let fileSelected = false;

        if (type === "image") {
            fileSelected = imageInput.files.length > 0;
        } else {
            fileSelected = videoInput.files.length > 0;
        }

        let textFilled = textarea.value.trim().length > 0;

        // enable/disable button
        btn.disabled = !(fileSelected && textFilled);
    }

    // 🔥 events
    imageInput.addEventListener("change", checkForm);
    videoInput.addEventListener("change", checkForm);
    textarea.addEventListener("input", checkForm);

    // 🔥 submit pe disable (duplicate stop)
    form.addEventListener("submit", () => {
        btn.disabled = true;
        btn.innerText = "Posting...";
    });

    // 🔥 initial state
    btn.disabled = true;
</script>

</body>

</html>